# VisionLoop — root env template. Copy each block to the relevant app .env file.
# Never commit real secrets; CI provides them via repository secrets.

# ──────────────────────────────────────────────────────────────────────
# apps/web/.env.local
# ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Better Auth — shared with the API for session validation
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-string
BETTER_AUTH_URL=http://localhost:3000

# OAuth (optional in dev; gated by presence of these vars)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Postgres URL used by Better Auth adapter
DATABASE_URL=postgres://visionloop:visionloop@localhost:5432/visionloop?sslmode=disable

# ──────────────────────────────────────────────────────────────────────
# apps/api/.env
# ──────────────────────────────────────────────────────────────────────
API_HTTP_ADDR=:8080
API_LOG_LEVEL=info
API_ENV=development

POSTGRES_URL=postgres://visionloop:visionloop@localhost:5432/visionloop?sslmode=disable
REDIS_URL=redis://localhost:6379/0
RABBITMQ_URL=amqp://visionloop:visionloop@localhost:5672/

# Cloudflare R2 (S3-compatible). For local dev we use MinIO.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_BUCKET=visionloop-dev
S3_FORCE_PATH_STYLE=true
S3_PRESIGN_EXPIRY_SECONDS=900

# Better Auth — same secret as the web app, used to verify session cookies
BETTER_AUTH_SECRET=replace-with-a-32-byte-random-string
WEB_ORIGIN=http://localhost:3000

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=visionloop-api

# Rate limiting
RATE_LIMIT_USER_PER_MIN=100
RATE_LIMIT_API_KEY_PER_MIN=1000

# ──────────────────────────────────────────────────────────────────────
# apps/ai-service/.env
# ──────────────────────────────────────────────────────────────────────
AI_HTTP_PORT=8000
AI_LOG_LEVEL=info
RABBITMQ_URL=amqp://visionloop:visionloop@localhost:5672/
REDIS_URL=redis://localhost:6379/1
API_CALLBACK_URL=http://api:8080/internal/jobs/callback
API_CALLBACK_TOKEN=replace-with-a-shared-secret

# Worker → API callback auth (consumed by apps/api). Both must be ≥32 bytes.
# JOB_CALLBACK_TOKEN is the shared bearer; JOB_CALLBACK_HMAC_SECRET signs the
# job_id (header X-Job-Signature) so a leaked bearer alone can't forge calls.
JOB_CALLBACK_TOKEN=replace-with-a-32+-byte-token-aaaaaaaa
JOB_CALLBACK_HMAC_SECRET=replace-with-a-32+-byte-hmac-secret-bbbb
MODEL_DIR=/models
ONNX_PROVIDERS=CPUExecutionProvider
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=visionloop-ai
